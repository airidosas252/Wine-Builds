diff --git a/dlls/win32u/winstation.c b/dlls/win32u/winstation.c
index eaa5f40..415529c 100644
--- a/dlls/win32u/winstation.c
+++ b/dlls/win32u/winstation.c
@@ -792,12 +792,37 @@ HWND get_desktop_window(void)
 {
     struct ntuser_thread_info *thread_info = NtUserGetThreadInfo();
     BOOL is_service;
+    BOOL is_desktop_explorer = FALSE;
 
     if (thread_info->top_window) return UlongToHandle( thread_info->top_window );
 
     /* don't create an actual explorer desktop window for services */
     is_service = is_service_process();
 
+    /* If this process is already explorer.exe /desktop, don't re-entrantly
+     * spawn another instance. During DLL init, GetDesktopWindow() may be
+     * called before wWinMain has created the desktop window. On X11 this is
+     * harmless (the second instance exits quickly), but on Wayland both
+     * instances create fullscreen surfaces causing a black screen.
+     * We still query the server -- just skip spawning a new explorer.exe. */
+    {
+        static const WCHAR explorerW[] = {'e','x','p','l','o','r','e','r','.','e','x','e',0};
+        static const WCHAR desktopW[] = {'/','d','e','s','k','t','o','p',0};
+        const WCHAR *imagepath = NtCurrentTeb()->Peb->ProcessParameters->ImagePathName.Buffer;
+        const WCHAR *cmdline = NtCurrentTeb()->Peb->ProcessParameters->CommandLine.Buffer;
+        const WCHAR *p;
+        if (imagepath)
+        {
+            p = wcsrchr(imagepath, '\\');
+            if (!p) p = wcsrchr(imagepath, '/');
+            if (p) p++; else p = imagepath;
+            if (!wcsicmp(p, explorerW) && cmdline)
+                for (p = cmdline; *p; p++)
+                    if (*p == '/' && !wcsnicmp(p, desktopW, 8) && (p[8] == 0 || p[8] == '=' || p[8] == ',' || p[8] == ' '))
+                    { is_desktop_explorer = TRUE; break; }
+        }
+    }
+
     SERVER_START_REQ( get_desktop_window )
     {
         req->force = is_service;
@@ -809,7 +834,7 @@ HWND get_desktop_window(void)
     }
     SERVER_END_REQ;
 
-    if (!thread_info->top_window)
+    if (!thread_info->top_window && !is_desktop_explorer)
     {
         static const WCHAR appnameW[] = {'\\','?','?','\\','C',':','\\','w','i','n','d','o','w','s',
             '\\','s','y','s','t','e','m','3','2','\\','e','x','p','l','o','r','e','r','.','e','x','e',0};
