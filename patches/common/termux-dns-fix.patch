+/***********************************************************************
+ *           init_dns_config
+ *
+ * Ensure DNS resolution doesn't hang on systems without /etc/resolv.conf
+ * (e.g., Android/Termux where glibc's resolver has no config).
+ * Without this, gethostbyname/getaddrinfo will try 127.0.0.1:53 and
+ * block for 30+ seconds per attempt, causing services.exe to hang.
+ */
+static void init_dns_config(void)
+{
+    static const char *resolv_paths[] = {
+        "/data/data/com.termux/files/usr/glibc/etc/resolv.conf",
+        "/data/data/com.termux/files/usr/etc/resolv.conf",
+        NULL
+    };
+    const char *dns_server;
+    FILE *f;
+    int i;
+
+    /* Check if standard resolv.conf exists */
+    if (!access("/etc/resolv.conf", R_OK)) return;
+
+    /* Set short timeout as safety net - prevents long hangs even if
+     * resolv.conf creation below fails (e.g., permission denied) */
+    setenv("RES_OPTIONS", "timeout:1 attempts:1", 0);
+
+    /* Detect Termux and create resolv.conf with public DNS */
+    for (i = 0; resolv_paths[i]; i++)
+    {
+        if (access(resolv_paths[i], R_OK) == 0) return; /* already exists */
+    }
+
+    /* Allow override via WINE_DNS_SERVER env var */
+    dns_server = getenv("WINE_DNS_SERVER");
+    if (!dns_server) dns_server = "8.8.8.8";
+
+    for (i = 0; resolv_paths[i]; i++)
+    {
+        f = fopen(resolv_paths[i], "w");
+        if (f)
+        {
+            fprintf(f, "# Auto-generated by Wine for Termux\n");
+            fprintf(f, "nameserver %s\n", dns_server);
+            fprintf(f, "nameserver 1.1.1.1\n");
+            fclose(f);
+            return;
+        }
+    }
+}
+
 #ifdef __ANDROID__
 
 #ifndef WINE_JAVA_CLASS
@@ -2039,6 +2089,7 @@ static jstring wine_init_jni( JNIEnv *env, jobject obj, jobjectArray cmdline, jo
     init_paths();
     virtual_init();
     init_environment();
+    init_dns_config();
 
 #ifdef __i386__
     {
@@ -2326,6 +2377,7 @@ DECLSPEC_EXPORT void __wine_main( int argc, char *argv[] )
 
     virtual_init();
     init_environment();
+    init_dns_config();
 
 #ifdef __APPLE__
     apple_main_thread();
